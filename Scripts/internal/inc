common_addopts() {
    local addopts=
    local cfg=$(get_config)
    local rt=$(get_runtime)
    local tgt=$(get_target)
    
    [ -n "$cfg" ] && addopts+=" -$cfg"
    [ -n "$rt" ] && addopts+=" -$rt"
    [ -n "$tgt" ] && addopts+=" -$tgt" 
    echo "${addopts#Substr"${addopts%%[![:space:]]*}"}"
    return 0
}
#
# -----------------------------------------------------------------------------------
#
is_default_build() {
    local _nondefault_opts=0

    ! target_x86_64    && _nondefault_opts=$(expr $_nondefault_opts + 1)
    ! runtime_ucrt     && _nondefault_opts=$(expr $_nondefault_opts + 1)
    ! config_debug     && _nondefault_opts=$(expr $_nondefault_opts + 1)
    ! feature_wide     && _nondefault_opts=$(expr $_nondefault_opts + 1)
    ! feature_conpty   && _nondefault_opts=$(expr $_nondefault_opts + 1)
    feature_reentrant  && _nondefault_opts=$(expr $_nondefault_opts + 1)
    feature_winconsole && _nondefault_opts=$(expr $_nondefault_opts + 1)
    feature_spfuncs    && _nondefault_opts=$(expr $_nondefault_opts + 1)
    feature_interop    && _nondefault_opts=$(expr $_nondefault_opts + 1)
    feature_termlib    && _nondefault_opts=$(expr $_nondefault_opts + 1)

    [ $_nondefault_opts -ne 0 ] && return 1
    return 0
}

common_consistency_checks() {
    runtime_msvcrt && target_native && _fail "--msvcrt is a Windows specific option and cannot be used for native builds."
    runtime_ucrt   && target_native && _fail "--ucrt is a Windows specific option and cannot be used for native builds."
    feature_conpty && target_native && _fail "--conpty is a Windows specific option and cannot be used for native builds."
    feature_winconsole && target_native && _fail "--winconsole is a Windows specific option and cannot be used for native builds."
    target_x86 && runtime_ucrt && _fail "x86 builds for UCRT are not supported."
    target_aarch64 && runtime_msvcrt && _fail "--woa and --msvcrt are not compatible. Windows on ARM implies ucrt."
    ! target_native && ! feature_conpty && ! feature_winconsole && _fail "Cross builds must use ConPTY or Windows Console APIor both."
    return 0   
}

get_config_prefix() {
    target_x86_64 && runtime_ucrt && echo "$UCRT64_PREFIX" && return 0
    target_x86_64 && runtime_msvcrt && echo "$MINGW64_PREFIX" && return 0
    target_x86 && runtime_msvcrt && echo "$MINGW32_PREFIX" && return 0
    target_x86 && runtime_ucrt && _fail "--x86 requires -msvcrt"
    target_aarch64  && echo "${CLANG64ARM_PREFIX}" && return 0
    target_native   && echo "${NATIVE_PREFIX}" && return 0
    return 1
}

get_target_arch() {
    target_x86_64 && echo "x86_64" && return 0
    target_aarch64 && echo "aarch64" && return 0
    target_x86 && echo "i686" && return 0
    target_native && echo "$(uname -m)" && return 0
    return 1
}

base_os_prefix() {
    local prefix=WindowsCross    
    if target_native; then
        prefix=$(uname -s)
        prefix=${prefix,,}
    fi
    echo "$prefix"
    return 0
}

build_prefix() {
    local prefix=debug
    local arch=$(get_target_arch)
    local base=$(base_os_prefix)
    config_release && prefix=release
    echo "${prefix}/${base}/${arch}"
    return 0
}

get_suffix() {
    local sufft=
    local suffw=

    feature_wide && suffw=w
    feature_reentrant && sufft=t

    echo "${sufft}${suffw}"
    return 0
}

get_extra_suffix() {
    local s_suff=
    local i_suff=
    local p_suff=
    local c_suff=

    feature_spfuncs && s_suff=s
    feature_interop && i_suff=i
    if ! target_native; then
        feature_conpty && p_suff=p
        feature_winconsole && c_suff=c
    fi
    echo "${s_suff}${i_suff}${p_suff}${c_suff}"
    return 0
}

relative_builddir() {
    local suffix=$(get_suffix)$(get_extra_suffix)
    local pre=$(build_prefix)
    local config_prefix=$(get_config_prefix)
    common_consistency_checks
    echo "${pre}/nc${suffix}/${config_prefix}"
    return 0
}

relative_installbase() {
    local suffix=$(get_suffix)$(get_extra_suffix)
    local pre=$(build_prefix)
    common_consistency_checks
    echo "${pre}/nc${suffix}"
    return 0
}

relative_installdir() {
    local config_prefix=$(get_config_prefix)
    common_consistency_checks
    echo "$(relative_installbase)/${config_prefix}"
    return 0
}

get_host_bht() {
    target_x86_64 && runtime_ucrt && echo "x86_64-w64-mingw32ucrt" && return 0
    target_x86_64 && runtime_msvcrt && echo "x86_64-w64-mingw32" && return 0
    target_aarch64 && echo "aarch64-w64-mingw32" && return 0
    target_x86 && runtime_msvcrt && echo "i686-w64-mingw32" && return 0
    target_x86 && runtime_ucrt && _fail "-x86 requires -msvcrt"
    return 1
}
