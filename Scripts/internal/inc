. $SCRIPTS/internal/common

declare arg_config=()
declare -A arg_features=()
declare arg_runtime=()
declare arg_target=()
declare -A arg_options=()
declare -A arg_parameters=()

function has_feature() {
    local -n _features=$1
    local feature=$2
    [ ${_features[$feature]+_} ] && return 0
    return 1
}

function combine_features() {
    local -n _features=$1
    local _keys="${!_features[*]}"
    local combined= 
    local key
    for key in $_keys; do
        combined="$combined -$key"
    done
    echo $combined
}

function has_option() {
    local -n _options=$1
    local option=$2
    [ ${_options[$option]+_} ] && return 0
    return 1
}

function parse_args() {
    local -n config=$1
    local -n features=$2
    local -n runtime=$3
    local -n target=$4
    local -n options=$5
    local -n parameters=$6
    local err=
    local no_defaults=0
    local l_config
    local l_features
    local l_runtime
    local l_target
    local l_options

    shift 6
    if [ "$1" = "-no-defaults" ]; then
        no_defaults=1
        shift
    fi

    while [[ $# -gt 0 ]]
    do
	    case "$1" in
	        -ascii)
                features["ascii"]=1
	            ;;
            -wide)
                features["wide"]=1
	            ;;
            -reentrant)
                features["reentrant"]=1
	            ;;
            -winconsole)
                features["winconsole"]=1
                ;;
            -conpty)
                features["conpty"]=1
                ;;
            -interop)
                features["interop"]=1
                ;;
            -spfuncs)
                features["spfuncs"]=1
                ;;
            -termlib)
                features["termlib"]=1
                ;;
            -dynamic)
                features["dynamic"]=1
                ;;
            -native)
                target+=("native")
                ;;
            -x86_64)
                target+=("x86_64")
                ;;
            -aarch64)
                target+=("aarch64")
                ;;
            -x86)
                target+=("x86")
                ;;
            -msvcrt)
                runtime+=("msvcrt")
                ;;
            -ucrt)
                runtime+=("ucrt")
                ;;    
            -debug)
                config+=("debug")
                ;;
            -release)
                config+=("release")
                ;;
	        -log)
		        shift
                parameters["log"]="$1"
		        ;;
            -c|-clean)
                options["clean"]=1
                ;;
            -v|-verbose)
                options["verbose"]=1
                ;;
            -h|-help)
                options["help"]=1
                return 0
                ;;
	        --)
		        shift
		        break
		        ;;
            -*)
                _fail "Unknown option: $1"
                ;;
	        *)
		        err="$err $1"
		        ;;
	    esac
        shift
    done
    [ -n "$err" ] && _fail "Invalid commandline argument(s): $err"
    
    l_config="${#config[*]}"
    [ $l_config -eq 0 ] && [ $no_defaults -eq 0 ] && config+=("debug") && l_config=1
    [ $l_config -gt 1 ] && _fail "Multiple build configurations specified: ${config[*]}"

    l_features="${#features[*]}"
    has_feature features "ascii" && has_feature features "wide" && _fail "Cannot specify both ascii and wide features"
    if ! has_feature features "ascii" && ! has_feature features "wide"; then
        if [ $no_defaults -eq 0 ]; then
            features["wide"]=1
            l_features=1
        fi
    fi
    if [ "${target[0]}" != "native" ]; then
        ! has_feature features "winconsole" && ! has_feature features "conpty" && [ $no_defaults -eq 0 ] && features["conpty"]=1 && l_features=$(expr $l_features + 1)
    fi

    l_runtime="${#runtime[*]}"
    [ $l_runtime -eq 0 ] && [ "${target[0]}" != "native" ] && [ $no_defaults -eq 0 ] && runtime+=("ucrt") && l_runtime=1
    [ $l_runtime -gt 1 ] && _fail "Multiple runtimes specified: ${runtime[*]}"

    l_target="${#target[*]}"
    [ $l_target -eq 0 ] && [ $no_defaults -eq 0 ] && target+=("x86_64") && l_target=1
    [ $l_target -gt 1 ] && _fail "Multiple targets specified: ${target[*]}"

    l_options="${#options[*]}"

    set_logfile parameters
    _nc_verbose=${options["verbose"]+1}

    return 0
}

