#!/usr/bin/env bash
# See License.md in the project root for license information.
#
SCRIPTS=$(cd $(dirname $BASH_SOURCE) && pwd)
. $SCRIPTS/_inc

err=

_opt_debug=1
_opt_dynamic=0
_opt_libseparate=0
_opt_native=0
_opt_clean=0

opt_debug() {
    [ $_opt_debug -ne 0 ] && return 0
    return 1
}

opt_dynamic() {
    [ $_opt_dynamic -ne 0 ] && return 0
    return 1
}

opt_libseparate() {
    [ $_opt_libseparate -ne 0 ] && return 0
    return 1
}

opt_native() {
    [ $_opt_native -ne 0 ] && return 0
    return 1
}

opt_clean() {
    [ $_opt_clean -ne 0 ] && return 0
    return 1
}

get_options() {
    local err=
    while [[ $# -gt 0 ]]
    do
	    case "$1" in
            -c|--clean)
                _opt_clean=1
                ;;
            -N|--native)
                _opt_native=1
                ;;
            -n|--nodebug)
                _opt_debug=0
                ;;
            -v|--verbose)
                _opt_verbose=1
                ;;
            -d|--dynamic)
                _opt_dynamic=1
                ;;
            -l|--libseparate)
                _opt_libseparate=1
                ;;
            -h|--help)
                echo "Usage: $0 [options]"
                echo "Options:"
                echo "  -c, --clean           Clean build and install directories before building"
                echo "  -N, --native          Build for native execution in Linux (no cross-compilation)"
                echo "  -d, --dynamic         Build with shared libraries (default is static)"
                echo "  -l, --libseparate     Build separate tinfo library (default is combined with ncurses)"
                echo "  -n, --nodebug         Build without debug symbols and features"
                echo "  -v, --verbose         Enable verbose output"
                echo "  -h, --help            Show this help message and exit"
                exit 0
                ;;
	        --)
		        shift
		        break
		        ;;
            -*)
                _fail "Unknown option: $1"
                ;;    
	        *)
		        err="$err $1"
		        break
		        ;;
	    esac
        shift
    done
    [ -n "$err" ] && _fail "Invalid commandline argument(s): $err"
    return 0
}

get_options $@
[ $? -ne 0 ] && _fail "Invalid options: $err"

if ! opt_native; then
    in_container || _fail "Not running in devcontainer." 
fi

addopts=
! opt_debug && addopts="$addopts --nodebug"
opt_dynamic && addopts="$addopts --dynamic"
opt_libseparate && addopts="$addopts --libseparate" 
opt_clean   && addopts="$addopts --clean"
opt_verbose && addopts="$addopts --verbose"

if opt_native; then
    addopts="$addopts --native"
    ${SCRIPTS}/ncbuild $addopts
    ${SCRIPTS}/ncbuild $addopts --ascii
    ${SCRIPTS}/ncbuild $addopts --interop
    ${SCRIPTS}/ncbuild $addopts --spfuncs
    ${SCRIPTS}/ncbuild $addopts --ascii --interop
    ${SCRIPTS}/ncbuild $addopts --ascii --spfuncs
    ${SCRIPTS}/ncbuild $addopts --interop --spfuncs
    ${SCRIPTS}/ncbuild $addopts --ascii --interop --spfuncs
    if ! is_native_darwin; then
        _trace "We do not buiuld for reentrant on Darwin"
        ${SCRIPTS}/ncbuild $addopts --reentrant
        ${SCRIPTS}/ncbuild $addopts --ascii --reentrant
        ${SCRIPTS}/ncbuild $addopts --ascii --reentrant --interop
        ${SCRIPTS}/ncbuild $addopts --reentrant --interop
        ${SCRIPTS}/ncbuild $addopts --reentrant --spfuncs
        ${SCRIPTS}/ncbuild $addopts --ascii --reentrant --spfuncs
        ${SCRIPTS}/ncbuild $addopts --reentrant --interop --spfuncs
        ${SCRIPTS}/ncbuild $addopts --ascii --reentrant --interop --spfuncs
    fi
else
    for p in "" "--msvcrt" "--x86 --msvcrt" "--woa"
    do
        ${SCRIPTS}/ncbuild $addopts $p
        ${SCRIPTS}/ncbuild $addopts $p --ascii
        ${SCRIPTS}/ncbuild $addopts $p --reentrant
        ${SCRIPTS}/ncbuild $addopts $p --ascii --reentrant
    done
fi
exit 0
