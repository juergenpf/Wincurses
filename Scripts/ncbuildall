#!/usr/bin/env bash
# See License.md in the project root for license information.
#
SCRIPT=$(cd $(dirname $BASH_SOURCE) && pwd)
. $SCRIPT/_inc

err=

_opt_debug=1
_opt_dynamic=0
_opt_native=0
_opt_clean=0

opt_debug() {
    [ $_opt_debug -ne 0 ] && return 0
    return 1
}

opt_dynamic() {
    [ $_opt_dynamic -ne 0 ] && return 0
    return 1
}

opt_native() {
    [ $_opt_native -ne 0 ] && return 0
    return 1
}

opt_clean() {
    [ $_opt_clean -ne 0 ] && return 0
    return 1
}

get_options() {
    local G=$(get_getopt)
    eval set -- "$($G -o cNdnvh -l clean,native,dynamic,nodebug,verbose,help -- "$@")"

    while true
    do
	    case "$1" in
            -c|--clean)
                _opt_clean=1
                shift
                ;;
            -N|--native)
                _opt_native=1
                shift
                ;;
            -n|--nodebug)
                _opt_debug=0
                shift
                ;;
            -v|--verbose)
                _opt_verbose=1
                shift
                ;;
            -d|--dynamic)
                _opt_dynamic=1
                shift
                ;;
            -h|--help)
                echo "Usage: $0 [options]"
                echo "Options:"
                echo " -c, --clean            Clean build and install directories before building"
                echo "  -N, --native          Build for native execution in Linux (no cross-compilation)"
                echo "  -d, --dynamic         Build with shared libraries (default is static)"
                echo "  -n, --nodebug         Build without debug symbols and features"
                echo "  -v, --verbose         Enable verbose output"
                echo "  -h, --help            Show this help message and exit"
                shift
                exit 0
                ;;
	    --)
		    shift
		    break
		    ;;
	    *)
		    err="$err $1"
		    shift
		    break
		    ;;
	    esac
    done
}

get_options $@
[ -n "$err" ] && _fail "Invalid options: $err"

if ! opt_native; then
    in_container || _fail "Not running in devcontainer." 
fi

addopts=
! opt_debug && addopts="$addopts --nodebug"
opt_dynamic && addopts="$addopts --dynamic" 
opt_clean   && addopts="$addopts --clean"

if opt_native; then
    _trace "Building for native execution in Linux (no cross-compilation)"
    addopts="$addopts --native"
    ${SCRIPT}/ncbuild $addopts
    ${SCRIPT}/ncbuild $addopts --ascii
    ${SCRIPT}/ncbuild $addopts --reentrant
    ${SCRIPT}/ncbuild $addopts --interop
    ${SCRIPT}/ncbuild $addopts --spfuncs
    ${SCRIPT}/ncbuild $addopts --ascii --reentrant
    ${SCRIPT}/ncbuild $addopts --ascii --interop
    ${SCRIPT}/ncbuild $addopts --ascii --spfuncs
    ${SCRIPT}/ncbuild $addopts --reentrant --interop
    ${SCRIPT}/ncbuild $addopts --reentrant --spfuncs
    ${SCRIPT}/ncbuild $addopts --interop --spfuncs
    ${SCRIPT}/ncbuild $addopts --ascii --reentrant --interop
    ${SCRIPT}/ncbuild $addopts --ascii --reentrant --spfuncs
    ${SCRIPT}/ncbuild $addopts --ascii --interop --spfuncs
    ${SCRIPT}/ncbuild $addopts --reentrant --interop --spfuncs
    ${SCRIPT}/ncbuild $addopts --ascii --reentrant --interop --spfuncs
else
    _trace "Building for Windows using cross-compilation"
    for p in "" "--msvcrt" "--x86 --msvcrt" "--woa"
    do
        ${SCRIPT}/ncbuild $addopts $p
        ${SCRIPT}/ncbuild $addopts $p --ascii
        ${SCRIPT}/ncbuild $addopts $p --reentrant
        ${SCRIPT}/ncbuild $addopts $p --ascii --reentrant
    done
fi
exit 0
