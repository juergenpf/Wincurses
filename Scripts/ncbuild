#!/usr/bin/env bash
# See License.md in the project root for license information.
#
SCRIPTS=$(cd $(dirname $BASH_SOURCE) && pwd)
. $SCRIPTS/internal/inc

get_options() {
    parse_args arg_config arg_features arg_runtime arg_target arg_options arg_parameters "$@"
    [ $? -ne 0 ] && _fail "Error parsing options"

    opt_help && {
        cat << EOF
Usage: $SCRIPTNAME [options]
Options:

  Build configuration (default: debug): Only one of these options can be specified.

    -debug               Build debug version (This is the default)
    -release             Build release version

  Character width configuration (default: wide): Only one of these options can be specified.

    -ascii               Build ASCII version (8-Bit characters only)
    -wide                Build wide character version (Unicode support, this is the default)

  Reentrancy options (for improved thread safetyness)

    -reentrant           Build reentrant version (improved thread safety)

  Target architecture (default: x86_64): Only one of these options can be specified.
                         When not -native, this is the architeture of the Windows OS being targeted.  

    -x86_64              Build for x86_64 (amd64) architecture
    -aarch64             Build for aarch64 (arm64) architecture, Windows on ARM
    -x86                 Build for x86 (i686) architecture
    -native              Build for native execution in Linux or the host environment

  Windows console support (default: ConPTY): Only one of these options can be specified.
                         This is only allowd, when building for Windows. 

    -conpty              Build with ConPTY support (intended for Windows 10 1809 and later)   
    -winconsole          Build with winconsole support (intended for Windows older than Windows 10 1809)

  C-Runtime of the Windows target OS (default: UCRT): Only one of these options can be specified.
                         This is only allowd, when building for Windows.

    -ucrt                Build with UCRT runtime
    -msvcrt              Build with MSVCRT instead of UCRT

  Internal library configuration features:

    -interop             Build with interop features enabled
    -spfuncs             Build with sp-funcs support.
    -termlib             Build terminfo library only
    -dynamic             Build with shared libraries (default is static)

  Other options:
  
    -log <file>          Log verbose output to the specified file
    -c|-clean            Clean build and install directories before building
    -v|-verbose          Enable verbose output
    -h|-help             Show this help message and exit
EOF
        exit 0
    }

    return 0
}

get_options "$@"
[ $? -ne 0 ]  && _fail "Error parsing options"

if ! target_native; then
    in_container || _fail "Not running in devcontainer." 
fi

# avoid_hostrun

if is_default_build; then
    _trace "Running with default settings (Windows cross build with widec support, UCRT target, debug build)"
fi

common_consistency_checks

_trace "Build prefix: $(build_prefix)"
_trace "Configuration prefix: $(get_config_prefix)"
_trace "Library suffix: $(get_suffix)"
_trace "Relative build directory: $(relative_builddir)"
_trace "Relative install base: $(relative_installbase)"
_trace "Relative install directory: $(relative_installdir)"

build_bht=$(uname -m)-linux-gnu
host_bht=
if ! target_native; then
    host_bht=$(get_host_bht)
    env_file=$PROJROOT/.devcontainer/crossenvs/${host_bht}.env
    if [ -f "$env_file" ]; then
        _trace "Sourcing cross build environment from: ${env_file}"
        source "$env_file"
    else
        _fail "Cross build environment file not found: ${env_file}"
    fi  
    _trace "Host target compiler: ${host_bht}, Build environment: ${build_bht}"
else
    if is_native_darwin; then
	    _trace "On Darwin we use the system compiler toolchain for native builds"
	    export CC=cc
	    export CXX=c++
	    export CPP=cpp
	    export LD=ld
	    export NM=nm
	    export AR=ar
	    export RANLIB=ranlib
	    export AS=as
	    export OBJDUMP=objdump
	    export STRIP=strip
    fi
fi

# When we are running in WSL2, we need to generate a .gdbinit file that contains 
# the correct paths to the repository and the WSL distribution name. This file 
# will be used by GDB to set up the environment for debugging Wincurses in Windows.
# This is necessary because we compile inside the container and gdb cannot generate
# source file references that are resolvable under Windows later on.
gen_gdbinit() {
    local d
    local p 
    pushd "$PROJROOT" >/dev/null
    for p in $(for d in ncurses panel menu form test; do find ncurses/$d -type d ; done | grep -v package)
    do
        echo "directory //wsl.localhost/${WSL_DISTRO_NAME}${ORIGINAL_REPO_PATH}/${p}"
    done
    echo "directory //wsl.localhost/${WSL_DISTRO_NAME}${ORIGINAL_REPO_PATH}/build/$(relative_builddir)/include"
    popd >/dev/null
}

# When we are running in Parallels Desktop, we need to generate a .gdbinit file that 
# contains the correct paths to the repository in the MacOS filesystem.  
gen_gdbinit_prl() {
    local d
    local p
    local win_p 
    source "${PROJROOT}/.prlpath" 
    pushd "$PROJROOT" >/dev/null
    win_p="${WIN_REPO_PATH//\\/\/}"
    for p in $(for d in ncurses panel menu form test; do find ncurses/$d -type d ; done | grep -v package)
    do
        echo "directory ${win_p}/$p"
    done
    p="build/$(relative_builddir)/include"
    echo "directory ${win_p}/$p"
    popd >/dev/null
}


do_config() {
    local srcdir=$PROJROOT/ncurses
    local blddir=${PROJROOT}/${_relative_buildroot}/$(relative_builddir)
    local cfg=$srcdir/configure
    local dynopts=
    local opts=
    local cflags= 
    local ldflags=
    local prefix=$(get_config_prefix)

    [ -x "$cfg" ] || _fail "Configure script not found or not executable: $cfg"

    if ! target_native; then
        opts+=" --build=${build_bht} \
            --host=${host_bht} 
            --with-strip-program=${STRIP}"
    fi

    if feature_dynamic; then
        dynopts="--with-shared"
    else
        dynopts="--without-shared --with-static"
    fi

    if feature_conpty; then
        opts+=" --enable-conpty"
    else
        opts+=" --disable-conpty"
    fi

    if feature_winconsole; then
        opts+=" --enable-win-console"
    else
        opts+=" --disable-win-console"
    fi
    
    if feature_interop; then
        opts+=" --enable-interop"
    else
        opts+=" --disable-interop"
    fi
    
    if feature_spfuncs; then
        opts+=" --enable-sp-funcs"
    else
        opts+=" --disable-sp-funcs"
    fi
    
    if feature_reentrant; then
        opts+=" --enable-reentrant"
    else
        opts+=" --disable-reentrant"
    fi
    
    if feature_wide; then
        opts+=" --enable-widec"
    else
        opts+=" --disable-widec"
    fi

    if feature_termlib; then
        opts="$opts --with-termlib"
    else
        opts="$opts --without-termlib"
    fi

    if ! target_native; then
        if feature_winconsole; then
            cflags="$cflags"
        fi
        if runtime_msvcrt; then
            opts+=" --with-extra-suffix=-msvcrt"
        fi
        opts+=" --disable-home-terminfo \
            --disable-symlinks \
            --with-fallbacks=ms-terminal,xterm-256color,xterm,ansi,vt100 \
            --without-manpages"
            # we enforce PCRE2 usage on Windows build in this devcontainer.
            cflags="$cflags -DJPF=0 -I${PCRE2_ROOT}/include -DPCRE2_STATIC -DHAVE_REGEX_H=1 -DHAVE_REGEX_H_FUNCS=1"
            ldflags="$ldflags -L${PCRE2_ROOT}/lib"
    else
	    if is_native_darwin; then
            opts+=" --enable-home-terminfo \
                --enable-symlinks \
                --without-manpages"
	    else
            opts+=" --enable-home-terminfo \
                --enable-symlinks \
                --with-fallbacks=linux,screen-256color,screen,xterm-256color,xterm,vt100 \
                --without-manpages"
	    fi
    fi
    
    rm -rf "$blddir"
    mkdir -p "$blddir"
    _trace "Recreated build directory: ${blddir}"

    opts="$opts --with-normal \
        --with-pkg-config \
        --without-cxx --without-ada \
        $dynopts"
    
    if config_debug; then
        cflags="$cflags -g"
        opts="$opts \
            --without-manpages \
            --with-debug \
            --with-progs \
            --with-tests \
            --with-develop \
            --with-trace \
            --enable-asserts \
            --enable-database \
            --enable-db-install \
            --enable-warnings \
            --enable-assertions" 
    else
        opts="$opts \
            --without-debug \
            --without-progs \
            --without-tests \
            --without-develop \
            --without-trace \
            --disable-assertions \
            --enable-db-install"
    fi

    opts="$opts --disable-leaks \
        --disable-macros \
        --disable-getcap \
        --disable-hard-tabs \
        --disable-overwrite \
        --disable-termcap \
        --enable-opaque-curses \
        --enable-opaque-panel \
        --enable-opaque-menu \
        --enable-opaque-form \
        --enable-pc-files"

    if feature_dynamic; then
        if ! target_native; then
	        if ! is_native_darwin; then
		        ldflags="$ldflags -static-libgcc -Wl,-Bdynamic"
	        fi
        else
            ldflags="$ldflags -static-libgcc -Wl,-Bstatic -lwinpthread -Wl,-Bdynamic"
        fi
    fi
    opts=$(echo "$opts" | xargs)
    _trace "Configuration options: ${opts}"
    if [ "$SCRIPTNAME" = "ncbuildinfo" ]; then
	_log "Info for build:"
        echo "configure_options=\"${opts}\""
        echo "cflags=\"${cflags}\""
        echo "ldflags=\"${ldflags}\""
        return 0
    fi

    pushd "$blddir" >/dev/null
    if ! target_native; then
        # Add PCRE2 libraries to LIBS so they appear at the end of the link line
        CFLAGS="${cflags}" LDFLAGS="${ldflags}" LIBS="-lpcre2-posix -lpcre2-8" \
        ${cfg} ${opts} --prefix="/${prefix}" \
            --datadir="/${prefix}/share" \
            --srcdir="${srcdir}"
    else
        CFLAGS="${cflags}" LDFLAGS="${ldflags}" \
        ${cfg} ${opts} --prefix="/${prefix}" \
            --datadir="/${prefix}/share" \
            --srcdir="${srcdir}"
    fi
    popd >/dev/null
    if ! feature_dynamic; then
        echo "S" > "$blddir/.static"
        rm -f "$blddir/.dynamic"
    else
        echo "D" > "$blddir/.dynamic"
        rm -f "$blddir/.static"
    fi
}

do_build() {
    local srcdir=$PROJROOT/ncurses
    local blddir=${PROJROOT}/${_relative_buildroot}/$(relative_builddir)

    if option_clean; then
        _trace "Cleaning build directory: ${blddir}"
        rm -rf "${blddir}"
    fi
    _trace "Build directory: ${blddir}, creating..."
    mkdir -p "${blddir}"

    if [ ! -f "$blddir/Makefile" ]; then
        do_config
    else
        if ! feature_dynamic && [ -f "$blddir/.dynamic" ]; then
            _trace "Configuration mismatch: previously configured for dynamic, now static. Reconfiguring..."
            do_config
        elif feature_dynamic && [ -f "$blddir/.static" ]; then
            _trace "Configuration mismatch: previously configured for static, now dynamic. Reconfiguring..."
            do_config
        else
            _trace "Existing configuration matches current options. Skipping configuration step."
        fi
    fi

    make -j$(nproc) -C "$blddir"
    [ $? -ne 0 ] && _fail "Build failed"

    if config_debug; then
        if target_aarch64 && maybe_parallels_desktop; then
            gen_gdbinit_prl  > ${blddir}/test/.gdbinit
            _trace "Generated .gdbinit for Parallels Desktop: ${blddir}/test/.gdbinit"
        fi
        if in_wsl2; then
            gen_gdbinit > ${blddir}/test/.gdbinit
            _trace "Generated .gdbinit for WSL2: ${blddir}/test/.gdbinit"
        fi
    fi
    return 0
}

do_install() {
    local srcdir=$PROJROOT/ncurses
    local blddir=${PROJROOT}/${_relative_buildroot}/$(relative_builddir)
    local instdir=${PROJROOT}/${_relative_instroot}/$(relative_installbase)

    if option_clean; then
        _trace "Cleaning install directory: ${instdir}"
        rm -rf "${instdir}"
    fi
    _trace "Install directory: ${instdir}, creating..."
    mkdir -p "${instdir}"

    _trace "Installing to: ${instdir}"
    make -j$(nproc) -C "$blddir" install DESTDIR="$instdir"
    [ $? -ne 0 ] && _fail "Install failed"
    rm -rf "${instdir}/opt"
}

if [ "$SCRIPTNAME" = "ncbuildinfo" ]; then
cat <<EOF
features=$(combine_features arg_features)
prefix="$(get_config_prefix)"
library_suffix="$(get_suffix)"
extra_suffix="$(get_extra_suffix)"
relative_build_directory="$(relative_builddir)"
relative_install_base="$(relative_installbase)"
relative_install_directory="$(relative_installdir)" 
target_arch="$(get_target_arch)"
EOF
do_config
    exit 0
fi

do_build
[ $? -ne 0 ] && _fail "Build failed"

do_install
[ $? -ne 0 ] && _fail "Install failed"

exit 0
