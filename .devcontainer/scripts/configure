#!/usr/bin/env bash
# See License.md in the project root for license information.
#
SCRIPT=$(cd $(dirname $BASH_SOURCE) && pwd)
WORKSPACE=$(dirname $(dirname "$SCRIPT"))
HELPER=WincursesHelper.ps1

wsl_profile_helper() {
    local w=$(type -p where.exe)
    local p=
    local profile=
    local pdir=
    local f="${SCRIPT}/${HELPER}"
    local wp=$(wslpath -w "$WORKSPACE")
    local ewp=$(printf '%s' "$wp" | sed 's/\\/\\\\/g')
    [ -f "$f" ] || return 1
    [ -n "$w" ] || return 1
    p=$($w powershell.exe | tr -d '\r')
    [ -n "$p" ] || return 1
    p=$(wslpath -u "$p")
    [ -f "$p" ] || return 1
    profile=$($p \$PROFILE)
    [ -n "$profile" ] || return 1
    profile=$(wslpath -u "$profile")
    pdir=$(dirname "$profile")
    [ -n "$pdir" ] || return 1
    cat "$f" | sed -e "s|@REPOPATH@|$ewp|g"  > "${pdir}/${HELPER}"
    return 0
}

mac2unc() {
    local mac_path="$1"

    mac_path="$(cd "$(dirname "$mac_path")" && pwd)/$(basename "$mac_path")"

    if [[ "$mac_path" == /Users/"$USER"/* ]]; then
        local remains="${mac_path#/Users/$USER/}"
        remains="${remains//\//\\}"   # / → \\
        printf "\\\\\\\\Mac\\\\Home\\\\%s\n" "$remains"
        return 0
    fi

    if [[ "$mac_path" == /Volumes/* ]]; then
        local volume remains
        volume="$(echo "$mac_path" | cut -d/ -f3)"
        remains="$(echo "$mac_path" | cut -d/ -f4-)"
        remains="${remains//\//\\}"
        printf "\\\\\\\\Mac\\\\%s\\\\%s\n" "$volume" "$remains"
        return 0
    fi

    echo "Path cannot be translated" >&2
    return 1
}

prl_profile_helper() {
    local f="${SCRIPT}/${HELPER}"
    local pdir=~/Downloads
    local safe_p=$(printf '%s' "$PRLPATH" | sed 's/\\/\\\\/g')
    cat "$f" | sed -e "s|@REPOPATH@|$safe_p|g" > "${pdir}/${HELPER}"
    return 0
}

if [ -f /.dockerenv ]; then
    echo "Please do not run this command inside the container." >&2
    exit 1
fi

MSYS2PATH=
PRLPATH=
DISTRO=

case "$(uname -s)" in
    Darwin*)
        LOCALE="$(defaults read -g AppleLocale).UTF-8"
        TIMEZONE=$(sudo systemsetup -gettimezone | awk '{print $3}')
	if [ -f ~/Library/Preferences/Parallels/Windows.dat ]; then
	    PRLPATH=$(mac2unc "$WORKSPACE")
	    if [ -n "$PRLPATH" ]; then
        	msys_p="${PRLPATH//\\/\/}"
		T="${WORKSPACE}/.prlpath"
		echo "# This file is generated. Please don't modify or remove it" > "$T"
		echo "ORIGINAL_REPO_PATH='$WORKSPACE'" >> "$T"
		echo "WIN_REPO_PATH='$PRLPATH'" >> "$T"
        	echo "MSYS_REPO_PATH='$msys_p'" >> "$T"
		prl_profile_helper
        	echo "settings set target.source-map /workspaces/Wincurses $msys_p" > ~/Downloads/lldbinit.windows
	    fi
	fi
        ;;
    Linux*)
        uname -r | grep -q WSL2
        if [ $? -eq 0 ]; then
            DISTRO=$WSL_DISTRO_NAME
            MSYS2PATH="//wsl\$/${WSL_DISTRO_NAME}${WORKSPACE}"
            T="${WORKSPACE}/.wslpath"
	    echo "# This file is generated. Please don't modify or remove it" > "$T"
            echo "WSL_DISTRO_NAME='$DISTRO'" >> "$T"
            echo "ORIGINAL_REPO_PATH='$WORKSPACE'" >> "$T"
            echo "MSYS2_REPO_PATH='$MSYS2PATH'" >> "$T"
            echo "WIN_REPO_PATH='$(wslpath -w $WORKSPACE)'" >> "$T"
            wsl_profile_helper
        fi
        LOCALE=$(locale | grep -E '^(LC_ALL|LANG)=' | head -n1 | cut -d= -f2)
        [[ "$LOCALE" == *.UTF-8 ]] || LOCALE="${LOCALE}.UTF-8"
        TIMEZONE=$(readlink -f /etc/localtime | sed 's|.*/zoneinfo/||')
        ;;
    *)
        echo "Unsupported OS" >&2
        exit 1
        ;;
esac

[ -n "$TIMEZONE" ] || TIMEZONE="UTC"
[ -n "$LOCALE" ]   || LOCALE="en_US.UTF-8"

if [ -f "${SCRIPT}/../devcontainer.json.in" ]; then
    cat "${SCRIPT}/../devcontainer.json.in" | \
        sed "s|@LOCALE@|$LOCALE|g" | \
        sed "s|@DISTRO@|$DISTRO|g" | \
        sed "s|@REPOPATH@|$WORKSPACE|g" | \
        sed "s|@TZ@|$TIMEZONE|g" > "${SCRIPT}/../devcontainer.json"
else
    echo "Error: devcontainer.json.in not found in $SCRIPT/../" >&2
    exit 1
fi

exit 0
