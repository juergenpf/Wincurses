#!/usr/bin/env bash
# See License.md in the project root for license information.
#
SCRIPT=$(cd $(dirname $BASH_SOURCE) && pwd)
WORKSPACE=$(dirname $(dirname "$SCRIPT"))
HELPER=WincursesHelper.ps1

get_llvm_mingw_current_version() {
    local v=
    if [ -f "${SCRIPT}/../devcontainer.json" ]; then
        v=$(grep LLVM_MINGW_VERSION "${SCRIPT}/../devcontainer.json" | cut -d: -f2 | tr -d '",')
    fi
    echo $v
}

get_llvm_mingw_version() {
    local version=$(curl -sL https://api.github.com/repos/mstorsjo/llvm-mingw/releases/latest | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
    if [ -n "$version" ]; then
        echo "$version"
    else
        echo "Error: Unable to fetch llvm-mingw version ${llvm_mingw_version}" >&2
        echo ""
    fi
}

guess_llvm_toolchain() {
    local v=$(get_llvm_mingw_version)
    if [ -z "$v" ]; then
        v=$(get_llvm_mingw_current_version)
        if [ -z "$v" ]; then
            v="20260407"
        fi
    fi
    echo $v
}

wsl_profile_helper() {
    local T=$(mktemp)
    local w=$(type -p where.exe)
    local p=
    local profile=
    local pdir=
    local f="${SCRIPT}/${HELPER}"
    local wp=$(wslpath -w "$WORKSPACE")
    local ewp=$(printf '%s' "$wp" | sed 's/\\/\\\\/g')
    [ -f "$f" ] || return 1
    [ -n "$w" ] || return 1
    p=$($w powershell.exe | tr -d '\r')
    [ -n "$p" ] || return 1
    p=$(wslpath -u "$p")
    [ -f "$p" ] || return 1
    profile=$($p \$PROFILE)
    [ -n "$profile" ] || return 1
    profile=$(wslpath -u "$profile")
    pdir=$(dirname "$profile")
    [ -n "$pdir" ] || return 1
    local T=$(mktemp)
    cat "$f" | sed -e "s|@REPOPATH@|$ewp|g"  > "$T"
    cmp -s "$T" "${pdir}/${HELPER}"
    if [ $? -ne 0 ]; then
         echo "Updating $HELPER in $pdir ..." >&2
         mv "$T" "${pdir}/${HELPER}"
    else         
        echo "$HELPER in $pdir is up to date." >&2
        rm -f "$T"
    fi
    return 0
}

mac2unc() {
    local mac_path="$1"

    mac_path="$(cd "$(dirname "$mac_path")" && pwd)/$(basename "$mac_path")"

    if [[ "$mac_path" == /Users/"$USER"/* ]]; then
        local remains="${mac_path#/Users/$USER/}"
        remains="${remains//\//\\}"   # / → \\
        printf "\\\\\\\\Mac\\\\Home\\\\%s\n" "$remains"
        return 0
    fi

    if [[ "$mac_path" == /Volumes/* ]]; then
        local volume remains
        volume="$(echo "$mac_path" | cut -d/ -f3)"
        remains="$(echo "$mac_path" | cut -d/ -f4-)"
        remains="${remains//\//\\}"
        printf "\\\\\\\\Mac\\\\%s\\\\%s\n" "$volume" "$remains"
        return 0
    fi

    echo "Path cannot be translated" >&2
    return 1
}

prl_profile_helper() {
    local T=$(mktemp)
    local f="${SCRIPT}/${HELPER}"
    local pdir=~/Downloads
    local safe_p=$(printf '%s' "$PRLPATH" | sed 's/\\/\\\\/g')
    cat "$f" | sed -e "s|@REPOPATH@|$safe_p|g" > "$T"
    cmp -s "$T" "${pdir}/${HELPER}"
    if [ $? -ne 0 ]; then
         echo "Updating $HELPER in $pdir. Please copy into your Parallels Powershell Profile directory." >&2
        mv "$T" "${pdir}/${HELPER}"
    else         
        echo "$HELPER in $pdir is up to date." >&2
        rm -f "$T"
    fi
    return 0
}

if [ -f /.dockerenv ]; then
    echo "Please do not run this command inside the container." >&2
    exit 1
fi

MSYS2PATH=
PRLPATH=
DISTRO=

llvm_mingw_version=$(guess_llvm_toolchain)
echo "detected LLVM MinGW toolchain version: $llvm_mingw_version"

case "$(uname -s)" in
    Darwin*)
        LOCALE="$(defaults read -g AppleLocale).UTF-8"
        TIMEZONE=$(sudo systemsetup -gettimezone | awk '{print $3}')
	if [ -f ~/Library/Preferences/Parallels/Windows.dat ]; then
	    PRLPATH=$(mac2unc "$WORKSPACE")
	    if [ -n "$PRLPATH" ]; then
        	msys_p="${PRLPATH//\\/\/}"
		T="${WORKSPACE}/.prlpath"
		echo "# This file is generated. Please don't modify or remove it" > "$T"
		echo "ORIGINAL_REPO_PATH='$WORKSPACE'" >> "$T"
		echo "WIN_REPO_PATH='$PRLPATH'" >> "$T"
        	echo "MSYS_REPO_PATH='$msys_p'" >> "$T"
		prl_profile_helper
        	echo "settings set target.source-map /workspaces/Wincurses $msys_p" > ~/Downloads/lldbinit.windows
	    fi
	fi
        ;;
    Linux*)
        uname -r | grep -q WSL2
        if [ $? -eq 0 ]; then
            DISTRO=$WSL_DISTRO_NAME
            MSYS2PATH="//wsl\$/${WSL_DISTRO_NAME}${WORKSPACE}"
            T="${WORKSPACE}/.wslpath"
	    echo "# This file is generated. Please don't modify or remove it" > "$T"
            echo "WSL_DISTRO_NAME='$DISTRO'" >> "$T"
            echo "ORIGINAL_REPO_PATH='$WORKSPACE'" >> "$T"
            echo "MSYS2_REPO_PATH='$MSYS2PATH'" >> "$T"
            echo "WIN_REPO_PATH='$(wslpath -w $WORKSPACE)'" >> "$T"
            wsl_profile_helper
        fi
        LOCALE=$(locale | grep -E '^(LC_ALL|LANG)=' | head -n1 | cut -d= -f2)
        [[ "$LOCALE" == *.UTF-8 ]] || LOCALE="${LOCALE}.UTF-8"
        TIMEZONE=$(readlink -f /etc/localtime | sed 's|.*/zoneinfo/||')
        ;;
    *)
        echo "Unsupported OS" >&2
        exit 1
        ;;
esac

[ -n "$TIMEZONE" ] || TIMEZONE="UTC"
[ -n "$LOCALE" ]   || LOCALE="en_US.UTF-8"

if [ -f "${SCRIPT}/../devcontainer.json.in" ]; then
    T=$(mktemp)
    cat "${SCRIPT}/../devcontainer.json.in" | \
        sed "s|@LLVM_MINGW_VERSION@|$llvm_mingw_version|g" |\
        sed "s|@LOCALE@|$LOCALE|g" | \
        sed "s|@DISTRO@|$DISTRO|g" | \
        sed "s|@REPOPATH@|$WORKSPACE|g" | \
        sed "s|@TZ@|$TIMEZONE|g" > "$T"
    cmp -s "$T" "${SCRIPT}/../devcontainer.json"
    if [ $? -ne 0 ]; then
         echo "Updating devcontainer.json with current environment settings. " >&2
         echo "Please consider rebuilding the devcontainer" >&2
        mv "$T" "${SCRIPT}/../devcontainer.json"
    else
        rm -f "$T"
    fi
else
    echo "Error: devcontainer.json.in not found in $SCRIPT/../" >&2
    exit 1
fi

exit 0
