{
  "name": "Debian SID Windows Cross (MSVCRT + UCRT)",

  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "LLVM_MINGW_VERSION" : "@LLVM_MINGW_VERSION@",
      "TZ" : "@TZ@",
      "LOCALE": "@LOCALE@",
      "ORIGINAL_REPO_PATH": "@REPOPATH@",
      "WSL_DISTRO_NAME": "@DISTRO@"
    }
  },

  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "customizations": {
    "vscode": {
      "extensions": [
          "ms-vscode.cpptools",
	        "ms-vscode.cpptools-extension-pack",
          "ms-azuretools.vscode-docker",
          "eamodio.gitlens",
          "vadimcn.vscode-lldb"
      ]
    }
  },

  "postCreateCommand": "sudo apt-get update"
}
